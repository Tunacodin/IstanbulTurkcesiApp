{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "poc/static",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/exercises",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/exercises"
    },
    {
      "source": "/assess",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/assess"
    },
    {
      "source": "/available-clips",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/available-clips"
    },
    {
      "source": "/videos-with-words",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/videos-with-words"
    },
    {
      "source": "/word-clip/:word",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/word-clip/:word"
    },
    {
      "source": "/reference/:id",
      "destination": "https://tunacodin-istanbul-turkcesi.hf.space/reference/:id"
    },
    {
      "source": "/static/:path*",
      "destination": "/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
