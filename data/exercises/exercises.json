{
  "exercises": [
    {
      "id": "kelime-001",
      "type": "kelime",
      "text": "merhaba",
      "focus": "selamlaşma",
      "difficulty": 1,
      "notes": "Temel test örneği."
    },
    {
      "id": "tekerleme-001",
      "type": "tekerleme",
      "text": "şu köşe yaz köşesi şu köşe kış köşesi ortada su şişesi",
      "focus": "ş/s ayrımı",
      "difficulty": 3,
      "notes": "Klasik diksiyon tekerlemesi."
    },
    {
      "id": "tekerleme-002",
      "type": "tekerleme",
      "text": "kırk kartal kalkmış kırk kartalın kırkı da kalkık kanatlı kartalmış",
      "focus": "k tekrarı, akıcılık",
      "difficulty": 4,
      "notes": "Hız ve netlik testi."
    },
    {
      "id": "cumle-001",
      "type": "cümle",
      "text": "yarın sabah erken kalkacağım",
      "focus": "yazı-konuşma farkı (kalkacağım → kalkıcam değil, ama yumuşak)",
      "difficulty": 2,
      "notes": "Standart İstanbul Türkçesi'nde nasıl okunmalı, eğitmen kaydı referans alınacak."
    },
    {
      "id": "cumle-002",
      "type": "cümle",
      "text": "bugün hava çok güzel, parka gitmeyi düşünüyorum",
      "focus": "akıcılık, ünlü uyumu, virgül duraklaması",
      "difficulty": 2,
      "notes": "Orta uzunlukta günlük cümle."
    },
    {
      "id": "cumle-003",
      "type": "cümle",
      "text": "kâğıt üzerinde harika görünen plan, hayata geçtiğinde sorunlu çıktı",
      "focus": "uzun ünlü (kâğıt), ğ silme, akıcılık",
      "difficulty": 3,
      "notes": "Hem â hem ğ yumuşamasını test eder."
    },
    {
      "id": "tekerleme-003",
      "type": "tekerleme",
      "text": "bir berber bir berbere bre berber gel beraber bir berber dükkânı açalım demiş",
      "focus": "b/r tekrarı, hız, akıcılık",
      "difficulty": 5,
      "notes": "Klasik uzun tekerleme. â harfi 'dükkân'da."
    },
    {
      "id": "paragraf-001",
      "type": "paragraf",
      "text": "küçük bir kuş, açık pencereden odaya girdi. masanın üzerindeki kâğıtları gagasıyla karıştırdı, sonra hızla uçup gitti.",
      "focus": "uzun cümle akıcılığı, noktalama duraklaması, uzun ünlü",
      "difficulty": 4,
      "notes": "İki cümlelik kısa paragraf. Pipeline uzun girdide nasıl davranır test eder."
    },
    {
      "id": "tekerleme-m-001",
      "type": "tekerleme",
      "text": "bu mumcu'nun mumu umumumuzun mumudur",
      "focus": "M harfi tekrarı, dudak kontrolü",
      "difficulty": 3,
      "notes": "Mennan Şahin M harfi dersinden klasik m tekerlemesi."
    },
    {
      "id": "tekerleme-m-002",
      "type": "tekerleme",
      "text": "mehmet'in mercan tesbihinin imamesi imameli mi imamesiz mi",
      "focus": "M harfi, ardı ardına gelen seslerin akıcılığı",
      "difficulty": 4,
      "notes": "Mennan Şahin M harfi dersinden."
    },
    {
      "id": "tekerleme-p-001",
      "type": "tekerleme",
      "text": "pötikareli pijamalı paşa",
      "focus": "P harfi, dudak patlamalı sesi",
      "difficulty": 2,
      "notes": "P harfi pratiği için klasik."
    },
    {
      "id": "tekerleme-r-001",
      "type": "tekerleme",
      "text": "bir tarihte birader birikmiş borçlarını bir bir biriktirdi",
      "focus": "R harfi titretme, akıcılık",
      "difficulty": 4,
      "notes": "R harfi kontrol pratiği."
    },
    {
      "id": "tekerleme-s-001",
      "type": "tekerleme",
      "text": "saksıda süs sümbülü ve solgun salatalık",
      "focus": "S harfi, peltek olmama",
      "difficulty": 3,
      "notes": "Mennan Şahin S harfi dersi tarzında."
    },
    {
      "id": "tekerleme-l-001",
      "type": "tekerleme",
      "text": "lale lalezara lalezarı laleli'ye götürdü",
      "focus": "L harfi, dil ucu kontrolü",
      "difficulty": 3,
      "notes": "L harfi pratiği."
    },
    {
      "id": "tekerleme-n-001",
      "type": "tekerleme",
      "text": "nemli nesnel bir nesne nedeniyle nadiren nemlenir",
      "focus": "N harfi, burun rezonansı",
      "difficulty": 3,
      "notes": "N harfi pratiği."
    },
    {
      "id": "tekerleme-t-001",
      "type": "tekerleme",
      "text": "tek tük teyzeden tatlı tatlı tepsi tepsi tatlılar",
      "focus": "T harfi, sert ünsüz patlaması",
      "difficulty": 3,
      "notes": "T harfi pratiği."
    },
    {
      "id": "tekerleme-g-001",
      "type": "tekerleme",
      "text": "gözleri gri güzel genç gemicinin gemisi",
      "focus": "G harfi, ön damak ünsüzü",
      "difficulty": 3,
      "notes": "G harfi pratiği."
    },
    {
